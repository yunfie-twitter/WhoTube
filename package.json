{
  "name": "wholphin-music",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev:client": "node scripts/wait-for-url.mjs http://localhost:3000/openapi.json && vite",
    "dev:server": "tsx --env-file=.env watch src/server/index.ts",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json || true",
    "build": "npm run build:server && npm run build:client",
    "start": "node --env-file=.env dist/server/index.js"
  },
  "dependencies": {
    "@fastify/compress": "^8.3.1",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.1.3",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@logto/react": "^4.0.14",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.100.1",
    "bgutils-js": "^3.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fastify": "^5.8.5",
    "ffmpeg-static": "^5.3.0",
    "googlevideo": "^4.0.4",
    "jsdom": "^29.0.2",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^1.9.0",
    "pg": "^8.20.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "shaka-player": "^5.1.1",
    "tailwind-merge": "^3.5.0",
    "undici": "^7.1.1",
    "youtubei.js": "^17.0.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/jsdom": "^28.0.1",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  }
}
